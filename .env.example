# AWS credentials for an IAM user with DynamoDB read/write access.
# See README.md > "AWS DynamoDB setup" for step-by-step instructions.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2

# Table names (defaults shown below already match the code — only override
# if you named your tables differently).
DYNAMODB_BOOKINGS_TABLE=Bookings
DYNAMODB_LEADS_TABLE=Leads
